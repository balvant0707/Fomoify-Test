  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt
  shop                 String

  enabled              Boolean  @default(true)
  visitorMin           Int?
  visitorMax           Int?
  template             String?  @db.LongText
  iconKey              String?
  iconColor            String?
  refreshSeconds       Int?
  behavior             String?

  textColor            String?
  fontSize             Int?
  mobileFontSize       Int?
  iconSize             Int?
  spacing              Int?
  textWeight           String?
  customClass          String?

  alignment            String?
  topMargin            Int?
  bottomMargin         Int?
  productScope         String?
