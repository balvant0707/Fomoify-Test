{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign inventory_quantity = current_variant.inventory_quantity | default: 0
-%}

<div
  class="fomoify-product-info-block"
  data-fomoify-product-info-block
  data-fomoify-block-type="stock"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-product-inventory="{{ inventory_quantity }}"
>
</div>

<script>
(() => {
  const root = document.currentScript.previousElementSibling;
  if (!root || root.dataset.fomoifyLoaded === "1") return;
  root.dataset.fomoifyLoaded = "1";

  const shop = String(root.dataset.shopDomain || window.Shopify?.shop || "").trim().toLowerCase();
  const productId = String(root.dataset.productId || "").trim();
  const productHandle = String(root.dataset.productHandle || "").trim().toLowerCase();
  const inventory = Number(root.dataset.productInventory || 0);
  const proxyBases = ["/apps/fomo", "https://fomoify-test.vercel.app/proxy/fomo"];
  const visitorIdKey = "fomoify_visitor_id";

  const proxyUrl = (base, path) => new URL(`${base}/${path}`, window.location.origin);
  const fetchWithProxyFallback = async (path, params, options) => {
    for (let i = 0; i < proxyBases.length; i++) {
      const url = proxyUrl(proxyBases[i], path);
      Object.entries(params || {}).forEach(([key, value]) => {
        if (value !== undefined && value !== null && value !== "") {
          url.searchParams.set(key, value);
        }
      });
      const requestUrl =
        url.origin === window.location.origin ? `${url.pathname}${url.search}` : url.toString();
      try {
        const response = await fetch(requestUrl, options);
        if (response.ok || i === proxyBases.length - 1) return response;
      } catch (error) {
        if (i === proxyBases.length - 1) throw error;
      }
    }
    return null;
  };

  const ensureVisitorId = () => {
    const makeId = () => `v-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
    try {
      const existing = window.localStorage.getItem(visitorIdKey);
      if (existing) return existing;
      const fresh = makeId();
      window.localStorage.setItem(visitorIdKey, fresh);
      return fresh;
    } catch {
      return makeId();
    }
  };

  const trackView = () => {
    if (!shop || window.Shopify?.designMode) return;
    fetchWithProxyFallback("track", { shop }, {
      method: "POST",
      credentials: "same-origin",
      keepalive: true,
      body: JSON.stringify({
        eventType: "view",
        popupType: "stock-block",
        visitorId: ensureVisitorId(),
        productHandle,
        pagePath: window.location.pathname || "/",
        sourceUrl: window.location.href || "",
      }),
    }).catch(() => {});
  };

  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const toBool = (value, fallback = false) => {
    if (value === true || value === false) return value;
    if (value === undefined || value === null || value === "") return fallback;
    return ["1", "true", "yes", "on"].includes(String(value).toLowerCase());
  };

  const toNumber = (value, fallback = 0) => {
    const number = Number(value);
    return Number.isFinite(number) ? number : fallback;
  };

  const parseList = (value) => {
    if (Array.isArray(value)) return value.map(String);
    if (!value) return [];
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed.map(String) : [];
    } catch {
      return String(value)
        .split(",")
        .map((item) => item.trim())
        .filter(Boolean);
    }
  };

  const productMatches = (record) => {
    const scope = String(record?.productScope || "all").toLowerCase();
    if (scope !== "specific") return true;
    const selected = parseList(record?.selectedProductsJson);
    if (!selected.length) return false;
    return selected.some((item) => {
      const normalized = String(item).toLowerCase();
      return (
        normalized === productHandle ||
        normalized.endsWith(`/${productId}`) ||
        normalized === productId
      );
    });
  };

  const alignmentToJustify = (alignment) => {
    if (alignment === "center") return "center";
    if (alignment === "right") return "flex-end";
    return "flex-start";
  };

  const responsiveFontSize = (desktop, mobile) => {
    const desktopSize = toNumber(desktop, 16);
    const mobileSize = toNumber(mobile, desktopSize);
    return window.matchMedia?.("(max-width: 749px)")?.matches ? mobileSize : desktopSize;
  };

  const lineStyle = (record, dotSize) => [
    `display:flex`,
    `justify-content:${alignmentToJustify(record.alignment)}`,
    `margin-top:${Math.max(0, toNumber(record.topMargin, 0))}px`,
    `margin-bottom:${Math.max(0, toNumber(record.bottomMargin, 0))}px`,
    `--fomoify-product-info-size:${Math.max(8, dotSize)}px`,
  ].join(";");

  const textStyle = (record, highlightBg) => {
    const parts = [
      `display:inline-flex`,
      `align-items:center`,
      `gap:${Math.max(4, Math.round(toNumber(record.spacing, 12) / 2))}px`,
      `color:${escapeHtml(record.textColor || "#3F3F46")}`,
      `font-size:${responsiveFontSize(record.fontSize, record.mobileFontSize)}px`,
      `font-weight:${escapeHtml(record.textWeight || "500")}`,
      `line-height:1.35`,
    ];
    if (highlightBg) {
      parts.push(`background:${escapeHtml(highlightBg)}`);
      parts.push(`border-radius:999px`);
      parts.push(`padding:3px 10px`);
    }
    return parts.join(";");
  };

  const dotIconSvg = (key) => {
    const value = String(key || "none").toLowerCase();
    if (value === "none") return null;
    const attrs = `viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"`;
    if (value === "check") {
      return `<svg ${attrs}><path d="m4 10 4.5 4.5 7.5-8"/></svg>`;
    }
    if (value === "alert") {
      return `<svg ${attrs}><circle cx="10" cy="10" r="7.25"/><path d="M10 5.75v5"/><path d="M10 14.25h.01"/></svg>`;
    }
    if (value === "star") {
      return `<svg ${attrs} fill="currentColor" stroke="none"><path d="m10 2.6 2.15 4.35 4.8.7-3.48 3.4.82 4.78L10 13.58l-4.29 2.25.82-4.78-3.48-3.4 4.8-.7L10 2.6Z"/></svg>`;
    }
    if (value === "flame") {
      return `<svg ${attrs} fill="currentColor" stroke="none"><path d="M10 2c0 0-4 3.5-4 7.5a4 4 0 0 0 8 0C14 5.5 10 2 10 2Zm0 10a2 2 0 0 1-2-2c0-2 2-4 2-4s2 2 2 4a2 2 0 0 1-2 2Z"/></svg>`;
    }
    return null;
  };

  const dotAnimCSS = (key) => {
    const value = String(key || "none").toLowerCase();
    if (value === "ping") {
      return `
        @keyframes fomoifyStockDotPing {
          0% { transform: scale(1); opacity: 1; }
          70% { transform: scale(1.7); opacity: 0; }
          100% { transform: scale(1.7); opacity: 0; }
        }
        .fomoify-stock-dot--ping { animation: fomoifyStockDotPing 1.2s ease-out infinite; }
      `;
    }
    if (value === "beat" || value === "pulse") {
      return `
        @keyframes fomoifyStockDotBeat {
          0%, 100% { transform: scale(1); }
          50% { transform: scale(1.28); }
        }
        .fomoify-stock-dot--beat { animation: fomoifyStockDotBeat 0.75s ease-in-out infinite; }
      `;
    }
    return "";
  };

  const renderStock = (record) => {
    if (!record || !toBool(record.enabled, true) || !productMatches(record)) return "";
    if (inventory <= 0 && toBool(record.hideOutOfStock, false)) return "";

    const showQuantity = toBool(record.showProductQuantity, true);
    const fallbackQuantity = Math.max(0, toNumber(record.productQuantity, 0));
    const count = Number.isFinite(inventory) ? inventory : fallbackQuantity;
    const isOut = count <= 0;
    const threshold = Math.max(0, toNumber(record.lowStockThreshold, 0));
    const isLowStock = !isOut && threshold > 0 && count < threshold;

    const text = isOut
      ? String(record.outOfStockText || "Out of stock")
      : isLowStock
        ? String(record.lowStockText || "Only {count} left in stock").replace("{count}", count)
      : showQuantity
        ? String(record.quantityText || "Stock: {count} available").replace("{count}", count)
        : String(record.inStockText || "In stock");

    let dotColor;
    if (isOut) {
      dotColor = record.outStockDotColor || "#EF4444";
    } else if (isLowStock) {
      dotColor = record.lowStockDotColor || "#F59E0B";
    } else {
      dotColor = record.inStockDotColor || "#42D66B";
    }

    const dotSize = Math.max(8, toNumber(record.dotSize, 16));
    const customClass = escapeHtml(record.customClass || "");
    const hideOnMobile = toBool(record.hideOnMobile, false);
    const highlightBg = String(record.highlightBg || "").trim();
    const iconSvg = dotIconSvg(record.dotIcon);
    const animationStyle = String(record.dotAnimationStyle || "none").toLowerCase();
    const animCSS = dotAnimCSS(animationStyle);
    const animClass =
      animationStyle === "ping"
        ? " fomoify-stock-dot--ping"
        : (animationStyle === "beat" || animationStyle === "pulse")
          ? " fomoify-stock-dot--beat"
          : "";

    const dotOrIcon = iconSvg
      ? `<span aria-hidden="true" class="fomoify-stock-dot${animClass}" style="color:${escapeHtml(dotColor)};width:var(--fomoify-product-info-size);height:var(--fomoify-product-info-size);display:inline-grid;place-items:center;flex:0 0 auto;">${iconSvg}</span>`
      : `<span aria-hidden="true" class="fomoify-stock-dot${animClass}" style="width:var(--fomoify-product-info-size);height:var(--fomoify-product-info-size);display:inline-block;border-radius:999px;background:${escapeHtml(dotColor)};box-shadow:inset 0 0 0 2px rgba(255,255,255,.72);"></span>`;

    return `
      <style>
        @keyframes fomoifyStockIn {
          from { opacity: 0; transform: translateY(5px); }
          to   { opacity: 1; transform: translateY(0); }
        }
        ${animCSS}
        .fomoify-stock-row {
          animation: fomoifyStockIn 0.4s ease-out both;
        }
        ${hideOnMobile ? "@media (max-width: 749px) { .fomoify-product-info-row { display: none !important; } }" : ""}
        @media (prefers-reduced-motion: reduce) {
          .fomoify-stock-row { animation: none; }
          .fomoify-stock-dot { animation: none; }
        }
      </style>
      <div class="fomoify-product-info-row ${customClass}" style="${lineStyle(record, dotSize)}">
        <span class="fomoify-stock-row" style="${textStyle(record, highlightBg)}">
          ${dotOrIcon}
          <span>${escapeHtml(text)}</span>
        </span>
      </div>
    `;
  };

  const fetchRecord = async () => {
    const response = await fetchWithProxyFallback("popup", { table: "stock-block", shop }, {
      credentials: "same-origin",
      cache: "no-store",
    });
    if (!response.ok) return null;
    const payload = await response.json().catch(() => null);
    return Array.isArray(payload?.records) ? payload.records[0] : null;
  };

  fetchRecord()
    .then((record) => {
      const html = renderStock(record);
      root.innerHTML = html;
      root.hidden = !html;
      if (html) trackView();
    })
    .catch(() => {
      root.hidden = true;
    });
})();
</script>

{% schema %}
{
  "name": "Fomoify Stock",
  "target": "section"
}
{% endschema %}
