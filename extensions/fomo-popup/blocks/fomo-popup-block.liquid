{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign inventory_quantity = current_variant.inventory_quantity | default: 0
-%}

<div
  class="fomoify-product-info-block"
  data-fomoify-product-info-block
  data-fomoify-block-type="visitor"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-product-inventory="{{ inventory_quantity }}"
>
</div>

<script>
(() => {
  const root = document.currentScript.previousElementSibling;
  if (!root || root.dataset.fomoifyLoaded === "1") return;
  root.dataset.fomoifyLoaded = "1";

  const shop = String(root.dataset.shopDomain || window.Shopify?.shop || "").trim().toLowerCase();
  const productId = String(root.dataset.productId || "").trim();
  const productHandle = String(root.dataset.productHandle || "").trim().toLowerCase();
  const blockType = String(root.dataset.fomoifyBlockType || "visitor").toLowerCase();
  const proxyBase = "/apps/fomo";

  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const toBool = (value, fallback = false) => {
    if (value === true || value === false) return value;
    if (value === undefined || value === null || value === "") return fallback;
    return ["1", "true", "yes", "on"].includes(String(value).toLowerCase());
  };

  const toNumber = (value, fallback = 0) => {
    const number = Number(value);
    return Number.isFinite(number) ? number : fallback;
  };

  const parseList = (value) => {
    if (Array.isArray(value)) return value.map(String);
    if (!value) return [];
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed.map(String) : [];
    } catch {
      return String(value)
        .split(",")
        .map((item) => item.trim())
        .filter(Boolean);
    }
  };

  const productMatches = (record) => {
    const scope = String(record?.productScope || "all").toLowerCase();
    if (scope !== "specific") return true;
    const selected = parseList(record?.selectedProductsJson);
    if (!selected.length) return false;
    return selected.some((item) => {
      const normalized = String(item).toLowerCase();
      return (
        normalized === productHandle ||
        normalized.endsWith(`/${productId}`) ||
        normalized === productId
      );
    });
  };

  const alignmentToJustify = (alignment) => {
    if (alignment === "center") return "center";
    if (alignment === "right") return "flex-end";
    return "flex-start";
  };

  const responsiveFontSize = (desktop, mobile) => {
    const desktopSize = toNumber(desktop, 16);
    const mobileSize = toNumber(mobile, desktopSize);
    return window.matchMedia?.("(max-width: 749px)")?.matches ? mobileSize : desktopSize;
  };

  const lineStyle = (record, iconOrDotSize) => [
    `display:flex`,
    `justify-content:${alignmentToJustify(record.alignment)}`,
    `margin-top:${Math.max(0, toNumber(record.topMargin, 0))}px`,
    `margin-bottom:${Math.max(0, toNumber(record.bottomMargin, 0))}px`,
    `--fomoify-product-info-size:${Math.max(8, iconOrDotSize)}px`,
  ].join(";");

  const textStyle = (record) => [
    `display:inline-flex`,
    `align-items:center`,
    `gap:${Math.max(4, Math.round(toNumber(record.spacing, 12) / 2))}px`,
    `color:${escapeHtml(record.textColor || "#3F3F46")}`,
    `font-size:${responsiveFontSize(record.fontSize, record.mobileFontSize)}px`,
    `font-weight:${escapeHtml(record.textWeight || "500")}`,
    `line-height:1.35`,
  ].join(";");

  const iconFor = (key) => {
    const value = String(key || "").toLowerCase();
    if (value === "none") return "";
    const attrs = `viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"`;
    if (value === "personfilledicon") {
      return `<svg ${attrs} fill="currentColor" stroke="none"><path d="M10 10.25a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M3.5 17.25c.65-3.25 3-5.25 6.5-5.25s5.85 2 6.5 5.25"/></svg>`;
    }
    if (value.includes("person")) {
      return `<svg ${attrs}><circle cx="10" cy="6.5" r="3.25"/><path d="M3.75 17c.75-3.25 3-5.1 6.25-5.1s5.5 1.85 6.25 5.1"/></svg>`;
    }
    if (value.includes("magic")) {
      return `<svg ${attrs}><path d="M4.5 15.5 15.5 4.5"/><path d="m12.8 4.2 3 3"/><path d="M5 4.5V2.75"/><path d="M5 8.25V6.5"/><path d="M2.75 5.5H4.5"/><path d="M6.5 5.5h1.75"/><path d="M15 13.5v-1.75"/><path d="M15 17.25V15.5"/><path d="M12.75 14.5h1.75"/><path d="M16.5 14.5h1.75"/></svg>`;
    }
    if (value.includes("heart")) {
      return `<svg ${attrs}><path d="M10 17s-6-3.65-6-8.2A3.35 3.35 0 0 1 10 6.75a3.35 3.35 0 0 1 6 2.05C16 13.35 10 17 10 17Z"/></svg>`;
    }
    if (value.includes("location")) {
      return `<svg ${attrs}><path d="M15.5 8.5c0 4.4-5.5 8.75-5.5 8.75S4.5 12.9 4.5 8.5a5.5 5.5 0 1 1 11 0Z"/><circle cx="10" cy="8.5" r="1.75"/></svg>`;
    }
    if (value.includes("star")) {
      return `<svg ${attrs} fill="currentColor" stroke="none"><path d="m10 2.6 2.15 4.35 4.8.7-3.48 3.4.82 4.78L10 13.58l-4.29 2.25.82-4.78-3.48-3.4 4.8-.7L10 2.6Z"/></svg>`;
    }
    if (value.includes("alert")) {
      return `<svg ${attrs}><circle cx="10" cy="10" r="7.25"/><path d="M10 5.75v5"/><path d="M10 14.25h.01"/></svg>`;
    }
    if (value.includes("eyecheck")) {
      return `<svg ${attrs}><path d="M2.5 10s2.8-5 7.5-5 7.5 5 7.5 5-2.8 5-7.5 5-7.5-5-7.5-5Z"/><circle cx="10" cy="10" r="2.25"/><path d="m12.75 14.75 1.5 1.5 3-3"/></svg>`;
    }
    if (value.includes("social")) {
      return `<svg ${attrs}><path d="M4 14.5V5.75A1.75 1.75 0 0 1 5.75 4h8.5A1.75 1.75 0 0 1 16 5.75v5.5A1.75 1.75 0 0 1 14.25 13H7l-3 2.5Z"/><path d="M7 7.5h6"/><path d="M7 10h4"/></svg>`;
    }
    return `<svg ${attrs}><path d="M2.5 10s2.8-5 7.5-5 7.5 5 7.5 5-2.8 5-7.5 5-7.5-5-7.5-5Z"/><circle cx="10" cy="10" r="2.25"/></svg>`;
  };

  const animationDuration = (speed) => {
    if (speed === "fast") return "0.25s";
    if (speed === "slow") return "0.8s";
    return "0.45s";
  };

  const rowAnimationCSS = (style, speed) => {
    const dur = animationDuration(speed);
    if (!style || style === "none") return "";
    if (style === "fade") {
      return `
        @keyframes fomoifyVisitorFade {
          from { opacity: 0; }
          to   { opacity: 1; }
        }
        .fomoify-visitor-row { animation: fomoifyVisitorFade ${dur} ease-out both; }
      `;
    }
    if (style === "bounce") {
      return `
        @keyframes fomoifyVisitorBounce {
          0%   { opacity: 0; transform: translateY(-14px); }
          60%  { opacity: 1; transform: translateY(4px); }
          80%  { transform: translateY(-3px); }
          100% { transform: translateY(0); }
        }
        .fomoify-visitor-row { animation: fomoifyVisitorBounce ${dur} ease-out both; }
      `;
    }
    if (style === "zoom") {
      return `
        @keyframes fomoifyVisitorZoom {
          from { opacity: 0; transform: scale(0.8); }
          to   { opacity: 1; transform: scale(1); }
        }
        .fomoify-visitor-row { animation: fomoifyVisitorZoom ${dur} ease-out both; }
      `;
    }
    return `
      @keyframes fomoifyVisitorIn {
        from { opacity: 0; transform: translateX(-10px); }
        to   { opacity: 1; transform: translateX(0); }
      }
      .fomoify-visitor-row { animation: fomoifyVisitorIn ${dur} ease-out both; }
    `;
  };

  const renderVisitor = (record) => {
    if (!record || !toBool(record.enabled, true) || !productMatches(record)) return "";
    const min = Math.max(0, toNumber(record.visitorMin, 12));
    const max = Math.max(min, toNumber(record.visitorMax, 42));

    const computeCount = () =>
      String(record.behavior || "").toLowerCase() === "random"
        ? Math.round(min + Math.random() * (max - min))
        : Math.round((min + max) / 2);

    let count = computeCount();

    const buildText = (n) => {
      const prefix = record.prefixText ? String(record.prefixText) + " " : "";
      const suffix = record.suffixText ? " " + String(record.suffixText) : "";
      const body = String(record.template || "{count} people are viewing this product").replace("{count}", n);
      return prefix + body + suffix;
    };

    const icon = iconFor(record.iconKey);
    const iconSize = Math.max(10, toNumber(record.iconSize, 18));
    const customClass = escapeHtml(record.customClass || "");
    const hideOnMobile = toBool(record.hideOnMobile, false);
    const animStyle = String(record.animationStyle || "slide").toLowerCase();
    const animSpeed = String(record.animationSpeed || "normal").toLowerCase();
    const countInterval = Math.max(0, toNumber(record.countInterval, 0));

    const rowAnim = rowAnimationCSS(animStyle, animSpeed);

    const html = `
      <style>
        ${rowAnim}
        @keyframes fomoifyIconBeat {
          0%, 100% { transform: scale(1); }
          35%      { transform: scale(1.3); }
          65%      { transform: scale(0.88); }
        }
        .fomoify-visitor-icon {
          animation: fomoifyIconBeat 2.4s ease-in-out 0.6s infinite;
          transform-origin: center;
          will-change: transform;
        }
        ${hideOnMobile ? "@media (max-width: 749px) { .fomoify-visitor-row-wrap { display: none !important; } }" : ""}
        @media (prefers-reduced-motion: reduce) {
          .fomoify-visitor-row  { animation: none; }
          .fomoify-visitor-icon { animation: none; }
        }
      </style>
      <div class="fomoify-visitor-row-wrap" style="${lineStyle(record, iconSize)}">
        <span id="fomoify-visitor-row" class="fomoify-visitor-row ${customClass}" style="${textStyle(record)}">
          ${icon ? `<span aria-hidden="true" class="fomoify-visitor-icon" style="color:${escapeHtml(record.iconColor || "#6B4B7A")};width:var(--fomoify-product-info-size);height:var(--fomoify-product-info-size);display:inline-grid;place-items:center;flex:0 0 auto;">${icon}</span>` : ""}
          <span id="fomoify-visitor-text">${escapeHtml(buildText(count))}</span>
        </span>
      </div>
    `;

    return { html, countInterval, buildText, min, max, behavior: record.behavior };
  };

  const fetchRecord = async (table) => {
    const url = new URL(`${proxyBase}/popup`, window.location.origin);
    url.searchParams.set("table", table);
    if (shop) url.searchParams.set("shop", shop);
    const response = await fetch(`${url.pathname}${url.search}`, {
      credentials: "same-origin",
      cache: "no-store",
    });
    if (!response.ok) return null;
    const payload = await response.json().catch(() => null);
    return Array.isArray(payload?.records) ? payload.records[0] : null;
  };

  fetchRecord(blockType === "stock" ? "stock-block" : "visitor-block")
    .then((record) => {
      const result = renderVisitor(record);
      if (!result || !result.html) {
        root.hidden = true;
        return;
      }
      root.innerHTML = result.html;
      root.hidden = false;

      if (result.countInterval > 0) {
        const textEl = root.querySelector("#fomoify-visitor-text");
        if (textEl) {
          setInterval(() => {
            const isRandom = String(record?.behavior || "").toLowerCase() === "random";
            if (!isRandom) return;
            const min = Math.max(0, Number(record?.visitorMin || 12));
            const max = Math.max(min, Number(record?.visitorMax || 42));
            const newCount = Math.round(min + Math.random() * (max - min));
            textEl.textContent = result.buildText(newCount);
          }, result.countInterval * 1000);
        }
      }
    })
    .catch(() => {
      root.hidden = true;
    });
})();
</script>

{% schema %}
{
  "name": "Fomoify Visitor",
  "target": "section"
}
{% endschema %}
